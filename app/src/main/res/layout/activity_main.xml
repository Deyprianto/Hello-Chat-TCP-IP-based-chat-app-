              />   TITLE -->

          <TextView
              android:layout_width="wrap_content"
              android:layout_height="wrap_content"
              android:text="Private rooms. Real-time chat."
              android:textSize="14sp"
              android:textColor="#6B7280"
              android:layout_marginTop="4dp"
              android:layout_marginBottom="44dp"/>

          <!-- CARD -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/bg_card"
            android:padding="20dp">

            <!-- SECTION LABEL -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="YOUR IDENTITY"
                android:textSize="10sp"
                android:letterSpacing="0.12"
                android:textColor="#4A6CF7"
                android:layout_marginBottom="10dp"/>

            <!-- NAME FIELD -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Nickname"
                android:textSize="12sp"
                android:textColor="#9CA3AF"
                android:layout_marginBottom="6dp"/>

            <EditText
                android:id="@+id/name"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:hint="e.g. tam"
                android:background="@drawable/bg_input"
                android:paddingHorizontal="14dp"
                android:textColor="#E5E7EB"
                android:textColorHint="#4B5563"
                android:textSize="14sp"
                android:inputType="text"
                android:layout_marginBottom="16dp"/>

            <!-- SERVER SECTION LABEL -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="SERVER"
                android:textSize="10sp"
                android:letterSpacing="0.12"
                android:textColor="#4A6CF7"
                android:layout_marginBottom="10dp"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Server IP"
                android:textSize="12sp"
                android:textColor="#9CA3AF"
                android:layout_marginBottom="6dp"/>

            <EditText
                android:id="@+id/ip"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:hint="192.168.1.x"
                android:background="@drawable/bg_input"
                android:paddingHorizontal="14dp"
                android:textColor="#E5E7EB"
                android:textColorHint="#4B5563"
                android:textSize="14sp"
                android:inputType="textUri"
                android:layout_marginBottom="16dp"/>

            <!-- ROOM SECTION LABEL -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="ROOM"
                android:textSize="10sp"
                android:letterSpacing="0.12"
                android:textColor="#4A6CF7"
                android:layout_marginBottom="10dp"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Room Name"
                android:textSize="12sp"
                android:textColor="#9CA3AF"
                android:layout_marginBottom="6dp"/>

            <EditText
                android:id="@+id/room"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:hint="general"
                android:background="@drawable/bg_input"
                android:paddingHorizontal="14dp"
                android:textColor="#E5E7EB"
                android:textColorHint="#4B5563"
                android:textSize="14sp"
                android:inputType="text"
                android:layout_marginBottom="12dp"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Password"
                android:textSize="12sp"
                android:textColor="#9CA3AF"
                android:layout_marginBottom="6dp"/>

            <EditText
                android:id="@+id/password"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:hint="Room password"
                android:background="@drawable/bg_input"
                android:paddingHorizontal="14dp"
                android:textColor="#E5E7EB"
                android:textColorHint="#4B5563"
                android:textSize="14sp"
                android:inputType="textPassword"/>

        </LinearLayout>

        <!-- BUTTONS -->
        <Button
            android:id="@+id/createBtn"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:text="Create Room"
            android:textColor="#FFFFFF"
            android:textSize="15sp"
            android:textStyle="bold"
            android:letterSpacing="0.02"
            android:backgroundTint="#4A6CF7"
            android:layout_marginTop="20dp"
            android:stateListAnimator="@null"/>

        <Button
            android:id="@+id/joinBtn"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:text="Join Room"
            android:textColor="#4A6CF7"
            android:textSize="15sp"
            android:textStyle="bold"
            android:backgroundTint="#1A2040"
            android:layout_marginTop="10dp"
            android:stateListAnimator="@null"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center_horizontal"
            android:layout_marginTop="24dp"
            android:text="End-to-end socket · Port 5000"
            android:textSize="11sp"
            android:textColor="#374151"/>

    </LinearLayout>
</ScrollView>