        <!--     <TextView
              android:layout_width="wrap_content"
              android:layout_height="wrap_content"
              android:text="Hello\nChat"
              android:textSize="30sp"
              android:textStyle="bold"
              android:letterSpacing="-0.03"
              android:textColor="#FFFFFF"
